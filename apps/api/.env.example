# MongoDB Atlas connection string
MONGODB_URI=

# Secret used to sign JWTs
JWT_SECRET=

# Groq API key for AI features (https://console.groq.com), free tier
GROQ_API_KEY=

# Groq model id (optional; defaults to llama-3.3-70b-versatile)
GROQ_MODEL=

# Port the API listens on (optional; defaults to 3000)
PORT=3000
